# =============================================================================
# RC Inbound SMS â†’ Zapier Webhook Integration
# Copy this file to .env and fill in the required values.
# =============================================================================

# â”€â”€ REQUIRED â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# A secret token YOU choose (e.g. a UUID). Must match what you enter in the
# RingCentral Developer Console when creating the webhook subscription.
RC_WEBHOOK_VERIFICATION_TOKEN=

# Your Zapier catch-hook HTTPS URL (must start with https://)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXXXX/XXXXXXX/

# â”€â”€ OPTIONAL (defaults shown) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Application environment: "development" enables /docs, "production" disables it
APP_ENV=production

# Server port
APP_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Zapier retry settings
ZAPIER_MAX_RETRIES=3
ZAPIER_RETRY_BASE_DELAY_SECONDS=1.0

# Idempotency cache settings
IDEMPOTENCY_CACHE_MAX_SIZE=10000
IDEMPOTENCY_CACHE_TTL_SECONDS=86400

# â”€â”€ SCRIPT-ONLY (used by scripts/create_subscription.py) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

