# =============================================================================
# RC Inbound SMS → Zapier Webhook Integration
# Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================================

# ------------------------------------------------------------------
# RingCentral Configuration
# ------------------------------------------------------------------
# The verification token you set when creating the webhook subscription
# in the RingCentral Developer Console. Must match the token RC sends
# in the "Verification-Token" header on every webhook push.
RC_WEBHOOK_VERIFICATION_TOKEN=your_rc_verification_token_here

# (Optional) RC OAuth credentials — only needed if you want the app
# to auto-register or renew the webhook subscription itself.
# RC_CLIENT_ID=your_rc_client_id
# RC_CLIENT_SECRET=your_rc_client_secret
# RC_SERVER_URL=https://platform.ringcentral.com

# ------------------------------------------------------------------
# Zapier Webhook
# ------------------------------------------------------------------
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXXXX/XXXXXXX/

# ------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------
# APP_ENV options: development | production
APP_ENV=production

# LOG_LEVEL options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Host and port for uvicorn (used in docker-compose / direct run)
APP_HOST=0.0.0.0
APP_PORT=8000

# ------------------------------------------------------------------
# Idempotency Cache
# ------------------------------------------------------------------
# Max number of message IDs to keep in memory (deduplication)
IDEMPOTENCY_CACHE_MAX_SIZE=10000
# How long (seconds) to remember a message ID before TTL expiry
IDEMPOTENCY_CACHE_TTL_SECONDS=86400

# ------------------------------------------------------------------
# Retry Configuration
# ------------------------------------------------------------------
# Number of retry attempts for failed Zapier webhook calls
ZAPIER_MAX_RETRIES=3
# Base delay in seconds for exponential backoff (1s → 2s → 4s)
ZAPIER_RETRY_BASE_DELAY_SECONDS=1.0
